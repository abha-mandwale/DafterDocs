APP_NAME=DafterDocs
APP_ENV=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["*"]

JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=1440

# Create the database first, e.g. `createdb dafterdocs`
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dafterdocs

STORAGE_DIR=storage
UPLOAD_DIR_NAME=uploads
EXPORT_DIR_NAME=exports
PROCESSING_STEP_DELAY_SECONDS=0.8
OCR_LANGUAGES=hin+eng
OCR_RENDER_SCALE=2.0
OCR_MAX_PAGES=25
OCR_TESSERACT_CONFIG=--oem 1 --psm 6
# Set only if tesseract binary is not in PATH
TESSERACT_CMD=
# Optional: force a Unicode TTF for PDF exports (recommended for Hindi).
PDF_FONT_PATH=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
